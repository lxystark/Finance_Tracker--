6. HashMap（哈希表）
用途： O(1)快速查找账户

python
复制
class HashMap:
    """哈希表"""
    def __init__(self, size=100):
        self.size = size
        self.buckets = [[] for _ in range(size)]   # 桶
    
    def _hash(self, key):
        return hash(key) % self.size
    
    def put(self, key, value):
        """存储"""
        index = self._hash(key)
        bucket = self.buckets[index]
        for i, (k, v) in enumerate(bucket):
            if k == key:
                bucket[i] = (key, value)
                return
        bucket.append((key, value))
    
    def get(self, key):
        """查找"""
        index = self._hash(key)
        bucket = self.buckets[index]
        for k, v in bucket:
            if k == key:
                return v
        return None
    
    def delete(self, key):
        """删除"""
        index = self._hash(key)
        bucket = self.buckets[index]
        for i, (k, v) in enumerate(bucket):
            if k == key:
                del bucket[i]
                return True
        return False
    
    def keys(self):
        """所有键"""
        result = []
        for bucket in self.buckets:
            for k, v in bucket:
                result.append(k)
        return result

# 测试
hm = HashMap()
hm.put("acc001", {"name": "张三", "balance": 1000})
hm.put("acc002", {"name": "李四", "balance": 2000})
print(hm.get("acc001"))   # 输出: {'name': '张三', 'balance': 1000}
