# 定义一个类
class Dog:
    def __init__(self, name, age):  # 构造方法，创建对象时自动调用
        self.name = name            # self.name是这个对象的"名字"属性
        self.age = age              # self.age是这个对象的"年龄"属性
    
    def bark(self):                  # 方法（类的函数）
        print(f"{self.name}在说: 汪!")

# 创建对象
dog1 = Dog("旺财", 3)   # 调用__init__，创建一只叫旺财、3岁的狗
dog2 = Dog("小白", 5)    # 创建另一只狗

# 调用方法
dog1.bark()   # 输出: 旺财在说: 汪!
dog2.bark()   # 输出: 小白在说: 汪!
解释：

__init__ 是"构造函数"，创建对象时自动运行
self 代表"我自己的"，指向当前创建的对象
self.name = name 把参数name存到对象里

