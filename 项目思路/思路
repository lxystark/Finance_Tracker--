class TreeNode:
    """树的节点"""
    def __init__(self, name):
        self.name = name
        self.children = []      # 子节点列表
        self.parent = None
    
    def add_child(self, child):
        child.parent = self
        self.children.append(child)
    
    def get_level(self):
        level = 0
        p = self.parent
        while p:
            level += 1
            p = p.parent
        return level
    
    def print_tree(self):
        spaces = "  " * self.get_level()
        print(spaces + self.name)
        for child in self.children:
            child.print_tree()

